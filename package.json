{
  "name": "ideafy",
  "version": "0.1.0",
  "description": "Kanban for Claude Code — local-first, AI-native task board",
  "author": "Ozan Gencer",
  "license": "MIT",
  "main": "electron/main.js",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "postinstall": "node ./scripts/prepare-dev-electron.mjs",
    "dev": "next dev -H 127.0.0.1 -p ${PORT:-3030}",
    "dev:clean": "rm -rf .next && next dev -H 127.0.0.1 -p ${PORT:-3030}",
    "dev:turbo": "rm -rf .next && next dev -H 127.0.0.1 -p ${PORT:-3030} --turbo",
    "build": "next build && rm -rf .next/standalone/data",
    "build:mcp": "cd mcp-server && npm install && npm run build",
    "start": "next start -H 127.0.0.1 -p ${PORT:-3030}",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "preelectron": "node ./scripts/prepare-dev-electron.mjs",
    "electron": "electron .",
    "rebuild:electron": "electron-builder install-app-deps",
    "rebuild:system": "npm rebuild better-sqlite3 && cd mcp-server && npm rebuild better-sqlite3",
    "pack": "npm run rebuild:system && npm run build && npm run build:mcp && electron-builder --dir && npm run rebuild:system",
    "dist": "npm run rebuild:system && npm run build && npm run build:mcp && electron-builder --mac && npm run rebuild:system"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/extension-image": "^3.15.3",
    "@tiptap/extension-placeholder": "^3.15.3",
    "@tiptap/extension-table": "^3.16.0",
    "@tiptap/extension-table-cell": "^3.16.0",
    "@tiptap/extension-table-header": "^3.16.0",
    "@tiptap/extension-table-row": "^3.16.0",
    "@tiptap/extension-task-item": "^3.15.3",
    "@tiptap/extension-task-list": "^3.15.3",
    "@tiptap/pm": "^3.15.3",
    "@tiptap/react": "^3.15.3",
    "@tiptap/starter-kit": "^3.15.3",
    "@tiptap/suggestion": "^3.15.3",
    "@types/markdown-it": "^14.1.2",
    "@types/turndown": "^5.0.6",
    "better-sqlite3": "^12.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "get-port": "^7.1.0",
    "isomorphic-dompurify": "^3.9.0",
    "lucide-react": "^0.562.0",
    "marked": "^17.0.1",
    "next": "^14.2.33",
    "next-themes": "^0.4.6",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "tippy.js": "^6.3.7",
    "tiptap-extension-resize-image": "^1.3.2",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "uuid": "11.0.5",
    "zustand": "5.0.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "22.10.7",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@types/uuid": "10.0.0",
    "autoprefixer": "^10.4.23",
    "drizzle-kit": "^0.31.8",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "eslint": "8.57.1",
    "eslint-config-next": "^14.2.33",
    "postcss": "8.5.1",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.3"
  },
  "build": {
    "appId": "com.ozangencer.ideafy",
    "productName": "Ideafy (Personal)",
    "copyright": "Copyright © 2026 Ozan Gencer",
    "afterPack": "./scripts/after-pack.mjs",
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "files": [
      "electron/**/*",
      "!electron/node_modules",
      "package.json"
    ],
    "extraResources": [
      { "from": ".next/standalone", "to": "app-next", "filter": ["!data/**"] },
      { "from": ".next/static", "to": "app-next/.next/static" },
      { "from": "public", "to": "app-next/public" },
      { "from": "drizzle", "to": "app-next/drizzle" },
      { "from": "skills", "to": "app-next/skills" },
      { "from": "mcp-server/dist", "to": "mcp-server/dist" },
      { "from": "mcp-server/node_modules", "to": "mcp-server/node_modules" }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "electron/icons/app-icon.icns",
      "target": [
        { "target": "dmg", "arch": ["x64"] },
        { "target": "dmg", "arch": ["arm64"] }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": true,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist"
    },
    "directories": {
      "output": "dist",
      "buildResources": "electron"
    }
  }
}
