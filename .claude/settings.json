{
  "mcpServers": {
    "ideafy": {
      "command": "npx",
      "args": [
        "tsx",
        "mcp-server/index.ts"
      ]
    }
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "# ideafy-hook\ncurl -sf -X POST -H \"Content-Type: application/json\" --data-binary @- \"http://localhost:${IDEAFY_PORT:-3030}/api/hook-context?card_hint=${IDEAFY_CARD_ID:-}\" 2>/dev/null"
          }
        ]
      }
    ]
  }
}